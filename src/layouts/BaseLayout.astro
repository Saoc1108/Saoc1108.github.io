---
// Importamos los estilos globales aquí para asegurar que carguen
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Portafolio Profesional" } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-zinc-950 text-zinc-300 antialiased selection:bg-red-900/50 selection:text-white font-sans">
    
    <!-- Floating Glassmorphism Navbar -->
    <div class="fixed top-4 left-0 right-0 z-50 px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto">
      <nav class="backdrop-blur-md bg-zinc-900/60 border border-zinc-800/80 rounded-full px-6 py-3 flex justify-between items-center shadow-lg transition-all duration-300 hover:border-zinc-700/80">
        <a href="#" class="font-bold text-lg tracking-tighter text-white font-display hover:text-red-500 transition-colors">
          SEBA<span class="text-red-600">.</span>OLMOS
        </a>
        <div class="flex items-center gap-5 sm:gap-6 text-sm font-medium">
          <a href="#about" class="text-zinc-400 hover:text-white transition-colors cursor-pointer">
            Sobre Mí
          </a>
          <a href="#projects" class="text-zinc-400 hover:text-white transition-colors cursor-pointer">
            Proyectos
          </a>
          <a href="https://github.com/Saoc1108/" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-red-500 transition-colors flex items-center gap-1 cursor-pointer">
            GitHub
          </a>
          <a href="https://linkedin.com/in/saoc" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-red-500 transition-colors flex items-center gap-1 cursor-pointer">
            LinkedIn
          </a>
        </div>
      </nav>
    </div>

    <!-- Main Container -->
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative pt-24">
      <main class="py-6">
        <slot />
      </main>

      <footer class="text-center text-sm text-zinc-650 py-12 border-t border-zinc-900 mt-20 font-mono">
        &copy; {new Date().getFullYear()} - Sebastián Olmos
      </footer>
    </div>
    
  </body>
</html>