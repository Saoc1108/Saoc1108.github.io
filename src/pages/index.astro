---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const allProjects = await getCollection("projects");
const sortedProjects = allProjects.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Sebastián Olmos | Portafolio">
  <!-- Hero Section -->
  <section class="min-h-[80vh] flex flex-col justify-center py-12 relative overflow-hidden">
    <!-- Abstract background glow -->
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-red-600/10 rounded-full blur-3xl -z-10 pointer-events-none"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-red-900/10 rounded-full blur-3xl -z-10 pointer-events-none"></div>

    <div class="space-y-8 max-w-4xl">
      <!-- Pulsing Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono bg-zinc-900/80 text-zinc-400 border border-zinc-800 shadow-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
        </span>
        Disponible para nuevos desafíos
      </div>

      <div class="space-y-4">
        <p class="text-zinc-500 font-mono text-sm tracking-widest uppercase">Hola, mi nombre es</p>
        <h1 class="text-5xl sm:text-7xl md:text-8xl font-bold font-display tracking-tight text-white leading-none">
          Sebastián <br class="hidden sm:inline" />
          <span class="bg-gradient-to-r from-white via-zinc-200 to-zinc-500 bg-clip-text text-transparent">
            Olmos Cordero
          </span>
        </h1>
      </div>

      <div class="border-l-2 border-red-650 pl-6 py-2 max-w-2xl">
        <h2 class="text-xl sm:text-2xl text-zinc-200 font-medium font-display">
          Ingeniero de Ejecución en Informática
        </h2>
        <p class="text-zinc-500 text-base mt-1 font-mono">
          Mención en Desarrollo de Sistemas
        </p>
      </div>

      <!-- Contact direct details grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-md pt-4 font-mono text-sm">
        <a 
          href="mailto:s.olmos1108@gmail.com" 
          class="flex items-center gap-3 px-4 py-3 bg-zinc-900/40 border border-zinc-800 hover:border-zinc-700 hover:text-white rounded-xl transition-all cursor-pointer group"
        >
          <div class="text-red-500 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
          </div>
          <span class="truncate">s.olmos1108@gmail.com</span>
        </a>

        <div class="flex items-center gap-3 px-4 py-3 bg-zinc-900/40 border border-zinc-800 rounded-xl cursor-default">
          <div class="text-red-500">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          </div>
          <span>Chile</span>
        </div>
      </div>

      <!-- Action buttons -->
      <div class="flex flex-wrap gap-4 pt-6">
        <a
          href="#projects"
          class="px-6 py-3.5 bg-red-700 hover:bg-red-655 text-white rounded-xl font-bold font-display transition-all shadow-[0_0_20px_-5px_rgba(220,38,38,0.4)] hover:shadow-[0_0_25px_-5px_rgba(220,38,38,0.6)] cursor-pointer"
        >
          Ver Proyectos
        </a>
        <a
          href="#about"
          class="px-6 py-3.5 bg-zinc-900 hover:bg-zinc-800 text-zinc-250 hover:text-white rounded-xl font-bold font-display transition-all border border-zinc-800 hover:border-zinc-700 cursor-pointer"
        >
          Sobre Mí
        </a>
        <a
          href="https://linkedin.com/in/saoc"
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-3.5 bg-zinc-900 hover:bg-zinc-800 text-zinc-250 hover:text-white rounded-xl font-bold font-display transition-all border border-zinc-800 hover:border-zinc-700 flex items-center gap-2 cursor-pointer"
        >
          LinkedIn 
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-24 border-t border-zinc-900 relative">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
      <!-- Profile Image -->
      <div class="md:col-span-5 relative group">
        <div class="absolute -inset-2 rounded-2xl bg-gradient-to-r from-red-600/20 to-rose-900/20 opacity-30 group-hover:opacity-60 transition duration-500 blur-xl"></div>
        <div class="relative overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-900 shadow-xl">
          <img
            src="/perfil.jpg"
            alt="Sebastián Olmos"
            class="w-full aspect-square object-cover grayscale contrast-[1.1] group-hover:grayscale-0 group-hover:scale-102 transition-all duration-700"
          />
        </div>
      </div>

      <!-- Profile Bio -->
      <div class="md:col-span-7 space-y-6">
        <h2 class="text-3xl sm:text-4xl font-bold text-white font-display flex items-center gap-3">
          <span class="text-red-500">/</span> Sobre Mí
        </h2>

        <div class="space-y-4 text-zinc-400 text-base sm:text-lg leading-relaxed">
          <p>
            Soy <strong class="text-white font-semibold">Ingeniero de Ejecución en Informática</strong> con mención en desarrollo de sistemas, titulado con distinción. Mi enfoque combina la rigurosidad técnica de la ingeniería con una capacidad creativa orientada a resolver problemas complejos.
          </p>
          <p>
            Cuento con <strong class="text-red-400 font-semibold">más de 5 años de experiencia</strong> desarrollando videojuegos independientes en Unity (C#) para Android, gestionando desde la programación de IAs hasta la publicación. En el ámbito web, tengo una base sólida en soluciones backend robustas con <strong class="text-white font-semibold">Python (Django) y .NET</strong>, priorizando siempre la seguridad informática y la optimización.
          </p>
          <p>
            Fuera de las líneas de código, me apasiona la restauración automotriz (actualmente trabajando en mi proyecto <em class="text-white not-italic font-semibold">"La Mosca"</em>) y el aprendizaje constante de nuevas arquitecturas de software.
          </p>
        </div>

        <!-- Quick Stats / Highlights -->
        <div class="grid grid-cols-3 gap-4 pt-4">
          <div class="p-4 bg-zinc-900/30 border border-zinc-800/80 rounded-xl text-center">
            <p class="text-2xl sm:text-3xl font-bold text-white font-display">+5</p>
            <p class="text-xs text-zinc-500 font-mono mt-1">Años Unity</p>
          </div>
          <div class="p-4 bg-zinc-900/30 border border-zinc-800/80 rounded-xl text-center">
            <p class="text-2xl sm:text-3xl font-bold text-white font-display">Titulado</p>
            <p class="text-xs text-zinc-500 font-mono mt-1">Con Distinción</p>
          </div>
          <div class="p-4 bg-zinc-900/30 border border-zinc-800/80 rounded-xl text-center">
            <p class="text-2xl sm:text-3xl font-bold text-white font-display">Backend</p>
            <p class="text-xs text-zinc-500 font-mono mt-1">Python / .NET</p>
          </div>
        </div>

        <!-- CV Button -->
        <div class="pt-6 flex flex-col gap-3 items-start">
          <button
            id="open-cv-modal"
            class="inline-flex items-center gap-2 px-6 py-3.5 bg-red-700 hover:bg-red-655 text-white rounded-xl font-bold font-display transition-all shadow-[0_0_20px_-5px_rgba(220,38,38,0.4)] cursor-pointer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
            Solicitar Currículum (CV)
          </button>
          <p class="text-xs text-zinc-500 font-mono">
            * Se requiere solicitud por correo para proteger datos personales sensibles.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline (Education & Experience) -->
  <section class="py-24 border-t border-zinc-900">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
      
      <!-- Education column -->
      <div class="space-y-10">
        <h3 class="text-2xl font-bold text-white font-display flex items-center gap-3">
          <span class="text-red-500">/</span> Formación
        </h3>
        
        <div class="space-y-8 relative pl-6 border-l border-zinc-850">
          <div class="relative group">
            <div class="absolute -left-[31px] top-1.5 w-3.5 h-3.5 rounded-full bg-zinc-950 border-2 border-red-500 group-hover:bg-red-500 transition-colors shadow-[0_0_8px_rgba(220,38,38,0.5)]"></div>
            <span class="text-xs font-mono text-zinc-550 uppercase">Instituto Profesional AIEP / Titulado</span>
            <h4 class="text-lg sm:text-xl font-bold text-white font-display mt-1 group-hover:text-red-400 transition-colors">
              Ingeniería de Ejecución en Informática
            </h4>
            <div class="flex flex-wrap gap-2 mt-2">
              <span class="px-2 py-0.5 bg-zinc-900 text-zinc-400 border border-zinc-800 rounded text-xs">Mención Desarrollo de Sistemas</span>
              <span class="px-2 py-0.5 bg-red-950/30 text-red-400 border border-red-900/30 rounded text-xs font-semibold">Distinción Máxima</span>
              <span class="px-2 py-0.5 bg-zinc-900 text-zinc-400 border border-zinc-800 rounded text-xs">Promedio 6.1</span>
            </div>
            <div class="mt-4 p-4 bg-zinc-900/30 border border-zinc-800/80 rounded-xl">
              <h5 class="text-xs font-mono text-zinc-500 uppercase tracking-wider mb-2 flex items-center gap-1.5">
                <span class="text-red-500">★</span> Excelencia Académica (Nota 7.0)
              </h5>
              <div class="flex flex-wrap gap-1.5">
                {["Seguridad Informática", "Gestión de Proyectos TI", "Minería de Datos"].map((subject) => (
                  <span class="px-2.5 py-1 bg-zinc-950 border border-zinc-850 rounded text-xs text-zinc-350">{subject}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Experience column -->
      <div class="space-y-10">
        <h3 class="text-2xl font-bold text-white font-display flex items-center gap-3">
          <span class="text-red-500">/</span> Experiencia
        </h3>
        
        <div class="space-y-8 relative pl-6 border-l border-zinc-850">
          <!-- Intelektas -->
          <div class="relative group">
            <div class="absolute -left-[31px] top-1.5 w-3.5 h-3.5 rounded-full bg-zinc-950 border-2 border-red-500 group-hover:bg-red-500 transition-colors shadow-[0_0_8px_rgba(220,38,38,0.5)]"></div>
            <span class="text-xs font-mono text-zinc-550 uppercase">2023 - 2025 / Ene. - Mar. (Periodos estivales)</span>
            <h4 class="text-lg sm:text-xl font-bold text-white font-display mt-1 group-hover:text-red-400 transition-colors">
              Desarrollador Backend / Asesor Externo TI
            </h4>
            <p class="text-sm text-zinc-400 font-medium">Sociedad Intelektas Capacitaciones Ltda.</p>
            <p class="text-sm text-zinc-500 mt-2 leading-relaxed">
              Desarrollo de aplicaciones web e implementación de sistemas de control de inventario. Diseño y despliegue de APIs REST para automatización. Colaboración ágil garantizando el cumplimiento de plazos críticos.
            </p>
          </div>

          <!-- CADES -->
          <div class="relative group">
            <div class="absolute -left-[31px] top-1.5 w-3.5 h-3.5 rounded-full bg-zinc-950 border-2 border-zinc-800 group-hover:border-red-500 transition-colors shadow-sm"></div>
            <span class="text-xs font-mono text-zinc-550 uppercase">2025 - 2026</span>
            <h4 class="text-lg sm:text-xl font-bold text-white font-display mt-1 group-hover:text-red-400 transition-colors">
              Relator Externo TI
            </h4>
            <p class="text-sm text-zinc-400 font-medium">Fundación CADES</p>
            <p class="text-sm text-zinc-500 mt-2 leading-relaxed">
              Capacitación técnica y formación de equipos en herramientas de ofimática (niveles básico, medio y avanzado). Más de 400 horas de relatoría teórica y práctica en modalidad presencial y remota.
            </p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Tech Stack -->
  <section class="py-24 border-t border-zinc-900 relative">
    <div class="space-y-12">
      <div>
        <h2 class="text-3xl font-bold text-white font-display flex items-center gap-3">
          <span class="text-red-500">/</span> Stack Tecnológico
        </h2>
        <p class="text-zinc-500 text-sm mt-2 font-mono">Herramientas y lenguajes con los que trabajo habitualmente</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {[
          { name: 'Python (Django)', desc: 'Desarrollo web y APIs' },
          { name: 'C# .NET', desc: 'Sistemas backend y servicios' },
          { name: 'Java', desc: 'Programación orientada a objetos' },
          { name: 'TypeScript', desc: 'Desarrollo web frontend moderno' },
          { name: 'Astro', desc: 'Sitios web estáticos optimizados' },
          { name: 'Unity', desc: 'Desarrollo de videojuegos 2D/3D' },
          { name: 'SQL / SQLite', desc: 'Gestión y modelado de BD' },
          { name: 'Tailwind CSS', desc: 'Diseño e interfaces ágiles' }
        ].map((tech) => (
          <div class="p-5 bg-zinc-900/20 border border-zinc-850 hover:border-red-500/30 hover:bg-zinc-900/40 rounded-xl transition-all duration-300 group hover:-translate-y-1 cursor-default shadow-sm">
            <h4 class="text-white font-bold font-display group-hover:text-red-400 transition-colors">{tech.name}</h4>
            <p class="text-zinc-550 text-xs mt-1.5 font-mono">{tech.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="py-24 border-t border-zinc-900">
    <div class="space-y-12">
      <div class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-4">
        <div>
          <h2 class="text-3xl sm:text-4xl font-bold text-white font-display">Proyectos Seleccionados</h2>
          <p class="text-zinc-555 text-sm mt-2 font-mono">Una muestra de desarrollos prácticos en videojuegos y web</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {
          sortedProjects.map((project) => (
            <article class="group relative bg-zinc-900/30 border border-zinc-850 rounded-2xl overflow-hidden hover:border-red-500/30 transition-all duration-350 hover:-translate-y-1.5 flex flex-col shadow-lg">

              {project.data.image && (
                <div class="relative h-52 w-full overflow-hidden border-b border-zinc-850 bg-zinc-950">
                  <Image
                    src={project.data.image}
                    alt={`Captura de pantalla de ${project.data.title}`}
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-103"
                    width={600}
                    height={300}
                  />
                  <!-- Hover overlay gradient -->
                  <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                </div>
              )}

              <div class="p-6 sm:p-8 flex-1 flex flex-col justify-between">
                <div>
                  <div class="flex gap-1.5 mb-4 flex-wrap">
                    {project.data.tags.map((tag) => (
                      <span class="text-[10px] sm:text-xs font-mono font-semibold px-2 py-0.5 rounded bg-zinc-950 border border-zinc-850 text-zinc-450 group-hover:text-red-400 group-hover:border-red-900/30 transition-colors">
                        {tag}
                      </span>
                    ))}
                  </div>

                  <h3 class="text-xl sm:text-2xl font-bold font-display text-white mb-2.5 group-hover:text-red-400 transition-colors">
                    {project.data.title}
                  </h3>

                  <p class="text-zinc-400 text-sm leading-relaxed mb-6 font-sans">
                    {project.data.description}
                  </p>
                </div>

                <div class="pt-5 border-t border-zinc-850/60 flex gap-4 mt-auto">
                  {project.data.repo && (
                    <a
                      href={project.data.repo}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs font-bold text-zinc-500 hover:text-white flex items-center gap-1.5 uppercase tracking-wide font-mono cursor-pointer transition-colors"
                    >
                      GitHub
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg>
                    </a>
                  )}
                  {project.data.link && (
                    <a
                      href={project.data.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs font-bold text-red-500 hover:text-red-450 flex items-center gap-1.5 uppercase tracking-wide font-mono cursor-pointer transition-colors"
                    >
                      Visitar Proyecto
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                    </a>
                  )}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CV Modal Form -->
  <div
    id="cv-modal"
    class="fixed inset-0 z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300 bg-zinc-950/80 backdrop-blur-sm"
  >
    <div
      id="cv-modal-content"
      class="relative w-full max-w-lg scale-95 opacity-0 transition-all duration-300 bg-zinc-900 border border-zinc-800 rounded-2xl p-6 md:p-8 shadow-2xl flex flex-col gap-6"
    >
      <!-- Close Button (X) -->
      <button
        id="close-cv-modal-x"
        class="absolute top-4 right-4 text-zinc-450 hover:text-white transition-colors cursor-pointer"
        aria-label="Cerrar modal"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg
        >
      </button>

      <div>
        <h3 class="text-2xl font-bold text-white font-display flex items-center gap-2">
          <span class="text-red-500">✉</span> Solicitar CV
        </h3>
        <p class="text-zinc-450 text-sm mt-2 leading-relaxed">
          Para proteger la privacidad de mis datos personales (teléfono, dirección, etc.), mi currículum se envía de forma directa y personalizada. Por favor, ingresa tus datos a continuación.
        </p>
      </div>

      <form id="cv-request-form" class="space-y-4">
        <div>
          <label for="request-name" class="block text-xs font-mono text-zinc-400 uppercase tracking-wider mb-2">
            Nombre / Empresa <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="request-name"
            required
            placeholder="Ej. Jane Doe / TechCorp"
            class="w-full px-4 py-3 bg-zinc-950 border border-zinc-850 rounded-xl text-white placeholder-zinc-700 focus:outline-none focus:border-red-600 transition-colors text-sm font-sans"
          />
        </div>

        <div>
          <label for="request-email" class="block text-xs font-mono text-zinc-400 uppercase tracking-wider mb-2">
            Tu Correo Electrónico <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="request-email"
            required
            placeholder="Ej. jane.doe@example.com"
            class="w-full px-4 py-3 bg-zinc-950 border border-zinc-850 rounded-xl text-white placeholder-zinc-700 focus:outline-none focus:border-red-600 transition-colors text-sm font-sans"
          />
        </div>

        <div>
          <label for="request-message" class="block text-xs font-mono text-zinc-400 uppercase tracking-wider mb-2">
            Mensaje <span class="text-red-500">*</span>
          </label>
          <textarea
            id="request-message"
            rows="4"
            required
            class="w-full px-4 py-3 bg-zinc-950 border border-zinc-850 rounded-xl text-white placeholder-zinc-700 focus:outline-none focus:border-red-600 transition-colors resize-none text-sm font-sans"
          >Hola Sebastián, he visto tu portafolio y me gustaría solicitar tu CV para revisar tu perfil profesional para una posible vacante.</textarea>
        </div>

        <div class="flex gap-3 pt-2 justify-end text-sm">
          <button
            type="button"
            id="close-cv-modal-btn"
            class="px-5 py-2.5 bg-zinc-850 hover:bg-zinc-800 text-zinc-300 rounded-xl font-semibold font-display transition-colors cursor-pointer border border-zinc-800"
          >
            Cancelar
          </button>
          <button
            type="submit"
            class="px-5 py-2.5 bg-red-700 hover:bg-red-655 text-white rounded-xl font-bold font-display transition-all shadow-[0_0_15px_rgba(220,38,38,0.4)] hover:shadow-[0_0_20px_rgba(220,38,38,0.6)] cursor-pointer"
          >
            Enviar Solicitud
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const modal = document.getElementById('cv-modal');
    const modalContent = document.getElementById('cv-modal-content');
    const openBtn = document.getElementById('open-cv-modal');
    const closeBtnX = document.getElementById('close-cv-modal-x');
    const closeBtn = document.getElementById('close-cv-modal-btn');
    const form = document.getElementById('cv-request-form');

    function openModal() {
      if (modal && modalContent) {
        modal.classList.remove('opacity-0', 'pointer-events-none');
        modal.classList.add('opacity-100');
        modalContent.classList.remove('scale-95', 'opacity-0');
        modalContent.classList.add('scale-100', 'opacity-100');
        document.body.style.overflow = 'hidden';
      }
    }

    function closeModal() {
      if (modal && modalContent) {
        modal.classList.remove('opacity-100');
        modal.classList.add('opacity-0', 'pointer-events-none');
        modalContent.classList.remove('scale-100', 'opacity-100');
        modalContent.classList.add('scale-95', 'opacity-0');
        document.body.style.overflow = '';
      }
    }

    if (openBtn) openBtn.addEventListener('click', openModal);
    if (closeBtnX) closeBtnX.addEventListener('click', closeModal);
    if (closeBtn) closeBtn.addEventListener('click', closeModal);

    if (modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          closeModal();
        }
      });
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeModal();
      }
    });

    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const nameInput = document.getElementById('request-name');
        const emailInput = document.getElementById('request-email');
        const messageInput = document.getElementById('request-message');

        const name = nameInput ? nameInput.value : '';
        const email = emailInput ? emailInput.value : '';
        const message = messageInput ? messageInput.value : '';

        const emailDestination = 's.olmos1108@gmail.com';
        const subject = `Solicitud de CV - ${name}`;
        const body = `Hola Sebastián,\n\nMi nombre es ${name} (correo de contacto: ${email}).\n\n${message}`;

        const mailtoUrl = `mailto:${emailDestination}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        
        window.location.href = mailtoUrl;

        setTimeout(closeModal, 500);
      });
    }
  </script>
</BaseLayout>
